<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.geometry.Insets?>
<?import javafx.scene.control.Button?>
<?import javafx.scene.control.Label?>
<?import javafx.scene.control.ScrollPane?>
<?import javafx.scene.control.TextField?>
<?import javafx.scene.layout.HBox?>
<?import javafx.scene.layout.VBox?>

<VBox alignment="CENTER" spacing="18.0"
      xmlns="http://javafx.com/javafx/21"
      xmlns:fx="http://javafx.com/fxml/1"
      fx:controller="org.example.mastermind.HelloController"
      style="-fx-background-color: linear-gradient(to bottom, #dbeafe, #eff6ff);">

    <padding>
        <Insets top="25" right="25" bottom="25" left="25"/>
    </padding>

    <VBox alignment="CENTER" spacing="16.0"
          prefWidth="720"
          maxWidth="720"
          style="-fx-background-color: white;
                 -fx-background-radius: 24;
                 -fx-border-radius: 24;
                 -fx-padding: 28;
                 -fx-effect: dropshadow(gaussian, rgba(0,0,0,0.15), 18, 0.2, 0, 4);">

        <Label text="Mastermind"
               style="-fx-font-size: 34px;
                      -fx-font-weight: bold;
                      -fx-text-fill: #1e3a8a;"/>

        <Label text="Erlaubte Farben: R, G, B, Y, O, P"
               style="-fx-font-size: 18px;
                      -fx-text-fill: #334155;"/>

        <Label fx:id="remainingLabel"
               text="Verbleibende Versuche: 10"
               style="-fx-font-size: 20px;
                      -fx-font-weight: bold;
                      -fx-text-fill: #0f766e;"/>

        <HBox alignment="CENTER" spacing="12">
            <TextField fx:id="inputField"
                       promptText="z.B. RGBY"
                       maxWidth="220"
                       onAction="#onSubmitButtonClick"
                       style="-fx-font-size: 18px;
                              -fx-background-radius: 12;
                              -fx-border-radius: 12;
                              -fx-padding: 10;
                              -fx-background-color: #f8fafc;
                              -fx-border-color: #93c5fd;
                              -fx-border-width: 2;"/>

            <Button text="Versuch prüfen"
                    onAction="#onSubmitButtonClick"
                    style="-fx-background-color: linear-gradient(to right, #2563eb, #1d4ed8);
                           -fx-text-fill: white;
                           -fx-font-size: 18px;
                           -fx-font-weight: bold;
                           -fx-background-radius: 12;
                           -fx-padding: 10 22 10 22;
                           -fx-cursor: hand;"/>

            <Button text="Erneut spielen"
                    onAction="#onRestartButtonClick"
                    style="-fx-background-color: linear-gradient(to right, #16a34a, #15803d);
                           -fx-text-fill: white;
                           -fx-font-size: 18px;
                           -fx-font-weight: bold;
                           -fx-background-radius: 12;
                           -fx-padding: 10 22 10 22;
                           -fx-cursor: hand;"/>
        </HBox>

        <Label fx:id="messageLabel"
               text="Statusmeldung"
               wrapText="true"
               maxWidth="560"
               style="-fx-font-size: 17px;
                      -fx-font-weight: bold;
                      -fx-text-fill: #b45309;"/>

        <ScrollPane fitToWidth="true"
                    prefHeight="340"
                    style="-fx-background: transparent; -fx-background-color: transparent;">
            <content>
                <VBox fx:id="historyBox"
                      spacing="10"
                      alignment="TOP_CENTER"
                      style="-fx-padding: 8;"/>
            </content>
        </ScrollPane>

    </VBox>
</VBox>