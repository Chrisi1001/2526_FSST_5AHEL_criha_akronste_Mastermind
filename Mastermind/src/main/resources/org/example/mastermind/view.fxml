<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.geometry.Insets?>
<?import javafx.scene.control.Button?>
<?import javafx.scene.control.Label?>
<?import javafx.scene.control.ScrollPane?>
<?import javafx.scene.layout.HBox?>
<?import javafx.scene.layout.StackPane?>
<?import javafx.scene.layout.VBox?>

<StackPane xmlns="http://javafx.com/javafx/21"
           xmlns:fx="http://javafx.com/fxml/1"
           fx:controller="org.example.mastermind.HelloController"
           style="-fx-background-color: #020617;">

    <VBox alignment="CENTER" spacing="20.0">
        <padding>
            <Insets top="30" right="30" bottom="30" left="30"/>
        </padding>

        <VBox alignment="CENTER" spacing="14.0"
              prefWidth="680" maxWidth="680"
              style="-fx-background-color: #0f172a;
                     -fx-background-radius: 20;
                     -fx-border-radius: 20;
                     -fx-border-color: #1e3a5f;
                     -fx-border-width: 1.5;
                     -fx-padding: 28;">

            <!-- ── Titel ── -->
            <VBox alignment="CENTER" spacing="4">
                <Label text="MASTERMIND"
                       style="-fx-font-size: 36px;
                              -fx-font-weight: bold;
                              -fx-text-fill: #e2e8f0;
                              -fx-font-family: 'Courier New';"/>
                <Label text="Ziehe Kugeln in die Felder · Klick zum Entfernen"
                       style="-fx-font-size: 12px;
                              -fx-text-fill: #475569;"/>
            </VBox>

            <!-- ── Farbpalette ── -->
            <VBox alignment="CENTER" spacing="8"
                  style="-fx-background-color: #0c1a2e;
                         -fx-background-radius: 14;
                         -fx-border-color: #1e3a5f;
                         -fx-border-width: 1;
                         -fx-border-radius: 14;
                         -fx-padding: 14 20 14 20;">
                <Label text="VERFÜGBARE FARBEN"
                       style="-fx-font-size: 10px;
                              -fx-font-weight: bold;
                              -fx-text-fill: #334155;
                              -fx-font-family: 'Courier New';"/>
                <HBox fx:id="paletteBox"
                      alignment="CENTER"
                      spacing="24"/>
            </VBox>

            <!-- ── Steuerleiste ── -->
            <HBox alignment="CENTER" spacing="10">
                <Label fx:id="remainingLabel"
                       text="Verbleibende Versuche: 10"
                       style="-fx-font-size: 13px;
                              -fx-font-weight: bold;
                              -fx-text-fill: #38bdf8;
                              -fx-font-family: 'Courier New';
                              -fx-background-color: #0c1a2e;
                              -fx-background-radius: 8;
                              -fx-padding: 6 14 6 14;
                              -fx-border-color: #1e3a5f;
                              -fx-border-width: 1;
                              -fx-border-radius: 8;"/>

                <Button text="▶  Prüfen"
                        onAction="#onSubmitButtonClick"
                        style="-fx-background-color: #1d4ed8;
                               -fx-text-fill: white;
                               -fx-font-size: 13px;
                               -fx-font-weight: bold;
                               -fx-background-radius: 10;
                               -fx-padding: 8 18 8 18;
                               -fx-cursor: hand;
                               -fx-border-color: #3b82f6;
                               -fx-border-width: 1;
                               -fx-border-radius: 10;"/>

                <Button text="💡  Tipp"
                        onAction="#onHintButtonClick"
                        style="-fx-background-color: #78350f;
                               -fx-text-fill: #fde68a;
                               -fx-font-size: 13px;
                               -fx-font-weight: bold;
                               -fx-background-radius: 10;
                               -fx-padding: 8 18 8 18;
                               -fx-cursor: hand;
                               -fx-border-color: #f59e0b;
                               -fx-border-width: 1;
                               -fx-border-radius: 10;"/>

                <Button text="↺  Neustart"
                        onAction="#onRestartButtonClick"
                        style="-fx-background-color: #15803d;
                               -fx-text-fill: white;
                               -fx-font-size: 13px;
                               -fx-font-weight: bold;
                               -fx-background-radius: 10;
                               -fx-padding: 8 18 8 18;
                               -fx-cursor: hand;
                               -fx-border-color: #22c55e;
                               -fx-border-width: 1;
                               -fx-border-radius: 10;"/>
            </HBox>

            <!-- ── Tipp-Popup (initial versteckt) ── -->
            <VBox fx:id="hintPopup"
                  alignment="CENTER"
                  spacing="10"
                  visible="false"
                  managed="false"
                  style="-fx-background-color: #1c1408;
                         -fx-background-radius: 14;
                         -fx-border-color: #f59e0b;
                         -fx-border-width: 1.5;
                         -fx-border-radius: 14;
                         -fx-padding: 16 24 16 24;">

                <Label text="Welchen Tipp möchtest du? (nur einmal pro Spiel!)"
                       style="-fx-font-size: 13px;
                              -fx-font-weight: bold;
                              -fx-text-fill: #fde68a;"/>

                <HBox alignment="CENTER" spacing="12">

                    <VBox alignment="CENTER" spacing="6"
                          style="-fx-background-color: #0f172a;
                                 -fx-background-radius: 12;
                                 -fx-border-color: #334155;
                                 -fx-border-width: 1;
                                 -fx-border-radius: 12;
                                 -fx-padding: 12 18 12 18;">
                        <Label text="💡  Leichter Tipp"
                               style="-fx-font-size: 13px;
                                      -fx-font-weight: bold;
                                      -fx-text-fill: #fbbf24;"/>
                        <Label text="1 unmögliche Farbe entfernen"
                               style="-fx-font-size: 11px;
                                      -fx-text-fill: #64748b;"/>
                        <Button text="Anwenden"
                                onAction="#onEasyHintClick"
                                style="-fx-background-color: #92400e;
                                       -fx-text-fill: #fde68a;
                                       -fx-font-size: 12px;
                                       -fx-font-weight: bold;
                                       -fx-background-radius: 8;
                                       -fx-padding: 6 16 6 16;
                                       -fx-cursor: hand;
                                       -fx-border-color: #f59e0b;
                                       -fx-border-width: 1;
                                       -fx-border-radius: 8;"/>
                    </VBox>

                    <VBox alignment="CENTER" spacing="6"
                          style="-fx-background-color: #0f172a;
                                 -fx-background-radius: 12;
                                 -fx-border-color: #334155;
                                 -fx-border-width: 1;
                                 -fx-border-radius: 12;
                                 -fx-padding: 12 18 12 18;">
                        <Label text="🔍  Starker Tipp"
                               style="-fx-font-size: 13px;
                                      -fx-font-weight: bold;
                                      -fx-text-fill: #fb923c;"/>
                        <Label text="2 unmögliche Farben entfernen"
                               style="-fx-font-size: 11px;
                                      -fx-text-fill: #64748b;"/>
                        <Button text="Anwenden"
                                onAction="#onStrongHintClick"
                                style="-fx-background-color: #7c2d12;
                                       -fx-text-fill: #fed7aa;
                                       -fx-font-size: 12px;
                                       -fx-font-weight: bold;
                                       -fx-background-radius: 8;
                                       -fx-padding: 6 16 6 16;
                                       -fx-cursor: hand;
                                       -fx-border-color: #fb923c;
                                       -fx-border-width: 1;
                                       -fx-border-radius: 8;"/>
                    </VBox>

                </HBox>

                <Button text="✕  Schließen"
                        onAction="#onHintButtonClick"
                        style="-fx-background-color: transparent;
                               -fx-text-fill: #475569;
                               -fx-font-size: 11px;
                               -fx-background-radius: 6;
                               -fx-padding: 4 12 4 12;
                               -fx-cursor: hand;
                               -fx-border-color: #1e293b;
                               -fx-border-width: 1;
                               -fx-border-radius: 6;"/>
            </VBox>

            <!-- ── Statusmeldung ── -->
            <Label fx:id="messageLabel"
                   text=""
                   wrapText="true"
                   maxWidth="500"
                   style="-fx-font-size: 14px;
                          -fx-font-weight: bold;
                          -fx-text-fill: #93c5fd;"/>

            <!-- ── Trennlinie ── -->
            <HBox prefHeight="1" maxHeight="1"
                  style="-fx-background-color: #1e293b;"/>

            <!-- ── Feedback-Legende ── -->
            <HBox alignment="CENTER" spacing="24">
                <HBox alignment="CENTER_LEFT" spacing="6">
                    <Label text="●" style="-fx-text-fill:#f8fafc;-fx-font-size:14px;"/>
                    <Label text="= richtige Farbe &amp; Position"
                           style="-fx-text-fill:#475569;-fx-font-size:11px;"/>
                </HBox>
                <HBox alignment="CENTER_LEFT" spacing="6">
                    <Label text="●" style="-fx-text-fill:#475569;-fx-font-size:14px;"/>
                    <Label text="= richtige Farbe, falsche Position"
                           style="-fx-text-fill:#475569;-fx-font-size:11px;"/>
                </HBox>
            </HBox>

            <!-- ── Spielbrett ── -->
            <ScrollPane fitToWidth="true"
                        prefHeight="360"
                        style="-fx-background:transparent;
                               -fx-background-color:transparent;
                               -fx-border-color:transparent;">
                <content>
                    <VBox fx:id="historyBox"
                          spacing="6"
                          alignment="TOP_CENTER"
                          style="-fx-padding: 4;"/>
                </content>
            </ScrollPane>

        </VBox>
    </VBox>
</StackPane>