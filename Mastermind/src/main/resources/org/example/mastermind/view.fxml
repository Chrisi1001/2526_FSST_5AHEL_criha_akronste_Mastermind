<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.geometry.Insets?>
<?import javafx.scene.control.Button?>
<?import javafx.scene.control.Label?>
<?import javafx.scene.control.ScrollPane?>
<?import javafx.scene.control.TitledPane?>
<?import javafx.scene.layout.HBox?>
<?import javafx.scene.layout.VBox?>
<?import javafx.scene.layout.StackPane?>
<?import javafx.scene.web.WebView?>

<StackPane xmlns="http://javafx.com/javafx/21"
           xmlns:fx="http://javafx.com/fxml/1"
           fx:controller="org.example.mastermind.HelloController"
           style="-fx-background-color: #020617;">

    <HBox alignment="CENTER" spacing="20">
        <padding>
            <Insets top="30" right="30" bottom="30" left="30"/>
        </padding>

        <TitledPane fx:id="instructionPane"
                    text="Spielanleitung"
                    expanded="false"
                    prefWidth="280"
                    maxWidth="280"
                    style="-fx-font-size: 14px;
                           -fx-font-weight: bold;
                           -fx-text-fill: #93c5fd;
                           -fx-background-color: #0f172a;
                           -fx-border-color: #1e3a5f;
                           -fx-border-width: 1.5;
                           -fx-border-radius: 12;
                           -fx-background-radius: 12;">
            <content>
                <WebView fx:id="instructionWebView"
                         prefWidth="278"
                         prefHeight="480"/>
            </content>
        </TitledPane>

        <VBox alignment="CENTER" spacing="18.0"
              prefWidth="680"
              maxWidth="680"
              style="-fx-background-color: #0f172a;
                     -fx-background-radius: 20;
                     -fx-border-radius: 20;
                     -fx-border-color: #1e3a5f;
                     -fx-border-width: 1.5;
                     -fx-padding: 28;">

            <VBox alignment="CENTER" spacing="4">
                <Label text="MASTERMIND"
                       style="-fx-font-size: 36px;
                              -fx-font-weight: bold;
                              -fx-text-fill: #e2e8f0;
                              -fx-font-family: 'Courier New';
                              -fx-letter-spacing: 6;"/>
                <Label text="Knacke den geheimen Farbcode!"
                       style="-fx-font-size: 13px;
                              -fx-text-fill: #475569;
                              -fx-letter-spacing: 1;"/>
            </VBox>

            <HBox fx:id="paletteBox"
                  alignment="CENTER"
                  spacing="14"
                  style="-fx-background-color: #0c1a2e;
                         -fx-background-radius: 14;
                         -fx-border-color: #1e3a5f;
                         -fx-border-width: 1;
                         -fx-border-radius: 14;
                         -fx-padding: 12 20 12 20;"/>

            <Label fx:id="remainingLabel"
                   text="Verbleibende Versuche: 10"
                   style="-fx-font-size: 15px;
                          -fx-font-weight: bold;
                          -fx-text-fill: #38bdf8;
                          -fx-font-family: 'Courier New';
                          -fx-background-color: #0c1a2e;
                          -fx-background-radius: 8;
                          -fx-padding: 6 16 6 16;
                          -fx-border-color: #1e3a5f;
                          -fx-border-width: 1;
                          -fx-border-radius: 8;"/>

            <HBox alignment="CENTER" spacing="10">
                <Button fx:id="submitButton"
                        text="Prüfen"
                        onAction="#onSubmitButtonClick"
                        style="-fx-background-color: #1d4ed8;
                               -fx-text-fill: white;
                               -fx-font-size: 14px;
                               -fx-font-weight: bold;
                               -fx-background-radius: 10;
                               -fx-padding: 9 20 9 20;
                               -fx-cursor: hand;
                               -fx-border-color: #3b82f6;
                               -fx-border-width: 1;
                               -fx-border-radius: 10;"/>

                <Button fx:id="restartButton"
                        text="Neustart"
                        onAction="#onRestartButtonClick"
                        style="-fx-background-color: #15803d;
                               -fx-text-fill: white;
                               -fx-font-size: 14px;
                               -fx-font-weight: bold;
                               -fx-background-radius: 10;
                               -fx-padding: 9 20 9 20;
                               -fx-cursor: hand;
                               -fx-border-color: #22c55e;
                               -fx-border-width: 1;
                               -fx-border-radius: 10;"/>

                <Button fx:id="hintButton"
                        text="Tipp"
                        onAction="#onHintButtonClick"
                        style="-fx-background-color: #7c3aed;
                               -fx-text-fill: white;
                               -fx-font-size: 14px;
                               -fx-font-weight: bold;
                               -fx-background-radius: 10;
                               -fx-padding: 9 20 9 20;
                               -fx-cursor: hand;
                               -fx-border-color: #a855f7;
                               -fx-border-width: 1;
                               -fx-border-radius: 10;"/>

                <Button fx:id="languageButton"
                        text="Sprache"
                        onAction="#onLanguageButtonclick"
                        style="-fx-background-color: #15803d;
                               -fx-text-fill: white;
                               -fx-font-size: 14px;
                               -fx-font-weight: bold;
                               -fx-background-radius: 10;
                               -fx-padding: 9 20 9 20;
                               -fx-cursor: hand;
                               -fx-border-color: #22c55e;
                               -fx-border-width: 1;
                               -fx-border-radius: 10;"/>
            </HBox>

            <VBox fx:id="hintPopup"
                  alignment="CENTER"
                  spacing="8"
                  visible="false"
                  managed="false"
                  style="-fx-background-color: #1e1b4b;
                         -fx-background-radius: 12;
                         -fx-border-color: #7c3aed;
                         -fx-border-width: 1.5;
                         -fx-border-radius: 12;
                         -fx-padding: 14 20 14 20;">
                <Label text="Welchen Tipp möchtest du?"
                       style="-fx-font-size: 13px;
                              -fx-font-weight: bold;
                              -fx-text-fill: #c4b5fd;"/>
                <HBox alignment="CENTER" spacing="10">
                    <Button text="Leicht  (1 Farbe ausblenden)"
                            onAction="#onEasyHintClick"
                            style="-fx-background-color: #4c1d95;
                                   -fx-text-fill: #e9d5ff;
                                   -fx-font-size: 13px;
                                   -fx-font-weight: bold;
                                   -fx-background-radius: 8;
                                   -fx-padding: 7 14 7 14;
                                   -fx-cursor: hand;
                                   -fx-border-color: #7c3aed;
                                   -fx-border-width: 1;
                                   -fx-border-radius: 8;"/>
                    <Button text="Stark  (2 Farben ausblenden)"
                            onAction="#onStrongHintClick"
                            style="-fx-background-color: #4c1d95;
                                   -fx-text-fill: #e9d5ff;
                                   -fx-font-size: 13px;
                                   -fx-font-weight: bold;
                                   -fx-background-radius: 8;
                                   -fx-padding: 7 14 7 14;
                                   -fx-cursor: hand;
                                   -fx-border-color: #7c3aed;
                                   -fx-border-width: 1;
                                   -fx-border-radius: 8;"/>
                </HBox>
            </VBox>

            <Label fx:id="messageLabel"
                   text="Statusmeldung"
                   wrapText="true"
                   maxWidth="500"
                   style="-fx-font-size: 14px;
                          -fx-font-weight: bold;
                          -fx-text-fill: #93c5fd;"/>

            <HBox prefHeight="1" maxHeight="1"
                  style="-fx-background-color: #1e293b;"/>

            <HBox alignment="CENTER" spacing="20">
                <HBox alignment="CENTER_LEFT" spacing="6">
                    <Label text="●" style="-fx-text-fill: #f8fafc; -fx-font-size: 14px;"/>
                    <Label text="= richtige Farbe &amp; Position"
                           style="-fx-text-fill: #64748b; -fx-font-size: 12px;"/>
                </HBox>
                <HBox alignment="CENTER_LEFT" spacing="6">
                    <Label text="●" style="-fx-text-fill: #475569; -fx-font-size: 14px;"/>
                    <Label text="= richtige Farbe, falsche Position"
                           style="-fx-text-fill: #64748b; -fx-font-size: 12px;"/>
                </HBox>
            </HBox>

            <ScrollPane fitToWidth="true"
                        prefHeight="360"
                        style="-fx-background: transparent;
                               -fx-background-color: transparent;
                               -fx-border-color: transparent;">
                <content>
                    <VBox fx:id="historyBox"
                          spacing="6"
                          alignment="TOP_CENTER"
                          style="-fx-padding: 4;"/>
                </content>
            </ScrollPane>

        </VBox>
    </HBox>
</StackPane>