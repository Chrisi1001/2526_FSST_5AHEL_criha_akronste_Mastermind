<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.geometry.Insets?>
<?import javafx.scene.control.Button?>
<?import javafx.scene.control.Label?>
<?import javafx.scene.control.ScrollPane?>
<?import javafx.scene.control.TextField?>
<?import javafx.scene.control.TitledPane?>
<?import javafx.scene.layout.HBox?>
<?import javafx.scene.layout.VBox?>
<?import javafx.scene.layout.StackPane?>
<?import javafx.scene.web.WebView?>

<StackPane xmlns="http://javafx.com/javafx/21"
           xmlns:fx="http://javafx.com/fxml/1"
           fx:controller="org.example.mastermind.HelloController"
           style="-fx-background-color: #020617;">

    <HBox alignment="CENTER" spacing="20">
        <padding>
            <Insets top="30" right="30" bottom="30" left="30"/>
        </padding>

        <!-- ══════════════════════════════════════════════════
             LINKE SEITE – aufklappbare Anleitung (WebView)
             ══════════════════════════════════════════════════ -->
        <TitledPane fx:id="instructionPane"
                    text="📖  Spielanleitung"
                    expanded="false"
                    prefWidth="280"
                    maxWidth="280"

                    style="-fx-font-size: 14px;
                           -fx-font-weight: bold;
                           -fx-text-fill: #93c5fd;
                           -fx-background-color: #0f172a;
                           -fx-border-color: #1e3a5f;
                           -fx-border-width: 1.5;
                           -fx-border-radius: 12;
                           -fx-background-radius: 12;">
            <content>
                <WebView fx:id="instructionWebView"
                         prefWidth="278"
                         prefHeight="480"/>
            </content>
        </TitledPane>

        <!-- ══════════════════════════════════════════════════
             RECHTE SEITE – Spielfeld
             ══════════════════════════════════════════════════ -->
        <VBox alignment="CENTER" spacing="18.0"
              prefWidth="680"
              maxWidth="680"
              style="-fx-background-color: #0f172a;
                     -fx-background-radius: 20;
                     -fx-border-radius: 20;
                     -fx-border-color: #1e3a5f;
                     -fx-border-width: 1.5;
                     -fx-padding: 28;">

            <VBox alignment="CENTER" spacing="4">
                <Label text="MASTERMIND"
                       style="-fx-font-size: 36px;
                              -fx-font-weight: bold;
                              -fx-text-fill: #e2e8f0;
                              -fx-font-family: 'Courier New';
                              -fx-letter-spacing: 6;"/>
                <Label text="Knacke den geheimen Farbcode!"
                       style="-fx-font-size: 13px;
                              -fx-text-fill: #475569;
                              -fx-letter-spacing: 1;"/>
            </VBox>

            <HBox alignment="CENTER" spacing="10">
                <Label text="R" style="-fx-background-color: #ef4444; -fx-text-fill: white; -fx-font-weight: bold; -fx-font-size: 13px; -fx-padding: 4 10 4 10; -fx-background-radius: 6;"/>
                <Label text="G" style="-fx-background-color: #22c55e; -fx-text-fill: white; -fx-font-weight: bold; -fx-font-size: 13px; -fx-padding: 4 10 4 10; -fx-background-radius: 6;"/>
                <Label text="B" style="-fx-background-color: #3b82f6; -fx-text-fill: white; -fx-font-weight: bold; -fx-font-size: 13px; -fx-padding: 4 10 4 10; -fx-background-radius: 6;"/>
                <Label text="Y" style="-fx-background-color: #ca8a04; -fx-text-fill: white; -fx-font-weight: bold; -fx-font-size: 13px; -fx-padding: 4 10 4 10; -fx-background-radius: 6;"/>
                <Label text="O" style="-fx-background-color: #f97316; -fx-text-fill: white; -fx-font-weight: bold; -fx-font-size: 13px; -fx-padding: 4 10 4 10; -fx-background-radius: 6;"/>
                <Label text="P" style="-fx-background-color: #a855f7; -fx-text-fill: white; -fx-font-weight: bold; -fx-font-size: 13px; -fx-padding: 4 10 4 10; -fx-background-radius: 6;"/>
            </HBox>

            <Label fx:id="remainingLabel"
                   text="Verbleibende Versuche: 10"
                   style="-fx-font-size: 15px;
                          -fx-font-weight: bold;
                          -fx-text-fill: #38bdf8;
                          -fx-font-family: 'Courier New';
                          -fx-background-color: #0c1a2e;
                          -fx-background-radius: 8;
                          -fx-padding: 6 16 6 16;
                          -fx-border-color: #1e3a5f;
                          -fx-border-width: 1;
                          -fx-border-radius: 8;"/>

            <HBox alignment="CENTER" spacing="10">
                <TextField fx:id="inputField"
                           promptText="z.B.  R G B Y"
                           maxWidth="200"
                           onAction="#onSubmitButtonClick"
                           style="-fx-font-size: 16px;
                                  -fx-font-family: 'Courier New';
                                  -fx-font-weight: bold;
                                  -fx-background-radius: 10;
                                  -fx-border-radius: 10;
                                  -fx-padding: 9 14 9 14;
                                  -fx-background-color: #1e293b;
                                  -fx-border-color: #334155;
                                  -fx-border-width: 1.5;
                                  -fx-text-fill: #e2e8f0;
                                  -fx-prompt-text-fill: #475569;"/>

                <Button text="▶  Prüfen"
                        onAction="#onSubmitButtonClick"
                        style="-fx-background-color: #1d4ed8;
                               -fx-text-fill: white;
                               -fx-font-size: 14px;
                               -fx-font-weight: bold;
                               -fx-background-radius: 10;
                               -fx-padding: 9 20 9 20;
                               -fx-cursor: hand;
                               -fx-border-color: #3b82f6;
                               -fx-border-width: 1;
                               -fx-border-radius: 10;"/>

                <Button text="↺  Neustart"
                        onAction="#onRestartButtonClick"
                        style="-fx-background-color: #15803d;
                               -fx-text-fill: white;
                               -fx-font-size: 14px;
                               -fx-font-weight: bold;
                               -fx-background-radius: 10;
                               -fx-padding: 9 20 9 20;
                               -fx-cursor: hand;
                               -fx-border-color: #22c55e;
                               -fx-border-width: 1;
                               -fx-border-radius: 10;"/>
            </HBox>

            <Label fx:id="messageLabel"
                   text="Statusmeldung"
                   wrapText="true"
                   maxWidth="500"
                   style="-fx-font-size: 14px;
                          -fx-font-weight: bold;
                          -fx-text-fill: #93c5fd;"/>

            <HBox prefHeight="1" maxHeight="1"
                  style="-fx-background-color: #1e293b;"/>

            <HBox alignment="CENTER" spacing="20">
                <HBox alignment="CENTER_LEFT" spacing="6">
                    <Label text="●" style="-fx-text-fill: #f8fafc; -fx-font-size: 14px;"/>
                    <Label text="= richtige Farbe &amp; Position"
                           style="-fx-text-fill: #64748b; -fx-font-size: 12px;"/>
                </HBox>
                <HBox alignment="CENTER_LEFT" spacing="6">
                    <Label text="●" style="-fx-text-fill: #475569; -fx-font-size: 14px;"/>
                    <Label text="= richtige Farbe, falsche Position"
                           style="-fx-text-fill: #64748b; -fx-font-size: 12px;"/>
                </HBox>
            </HBox>

            <ScrollPane fitToWidth="true"
                        prefHeight="360"
                        style="-fx-background: transparent;
                               -fx-background-color: transparent;
                               -fx-border-color: transparent;">
                <content>
                    <VBox fx:id="historyBox"
                          spacing="6"
                          alignment="TOP_CENTER"
                          style="-fx-padding: 4;"/>
                </content>
            </ScrollPane>

        </VBox>
    </HBox>
</StackPane>